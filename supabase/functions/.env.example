# ============================================================================
# Edge Function secrets (Supabase). These are NOT Vite/frontend env vars.
# Set them with the CLI or the dashboard (Project → Edge Functions → Secrets):
#   supabase secrets set KEY="value" KEY2="value2"
#   supabase secrets list
# Local dev with `supabase functions serve` can read this file:
#   supabase functions serve --env-file supabase/functions/.env
# Copy to supabase/functions/.env and fill in real values (never commit the real file).
# ============================================================================

# --- Auto-injected by the Supabase platform on deploy — do NOT set these yourself ---
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...        # used by strava-sync + google-calendar-sync (token tables)

# --- Optional alias the code also accepts for the service role key ---
# SERVICE_ROLE_KEY=                     # only needed if you didn't rely on SUPABASE_SERVICE_ROLE_KEY

# --- Anthropic (jarvis-chat) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6     # optional; defaults to claude-sonnet-4-6 in jarvis-chat

# --- Strava integration (strava-sync) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Google Calendar integration (google-calendar-sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- CORS allowlist (Phase 4A) ---
# Comma-separated. UNSET → Access-Control-Allow-Origin: '*' (works, but open).
# Set to your production origin(s) + localhost dev to lock CORS down:
#   supabase secrets set ALLOWED_ORIGINS="https://<your-prod-domain>,http://localhost:5173"
# Include EVERY origin the browser app is served from (prod domain, preview domains, localhost).
ALLOWED_ORIGINS=
